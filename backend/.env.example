# MiniMax API
MINIMAX_API_KEY=your_api_key_here
MINIMAX_MODEL=abab7

# 阿里云 OCR (可选，不配置则使用本地 pytesseract)
ALIYUN_OCR_API_KEY=
ALIYUN_OCR_API_SECRET=

# 文件存储
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# 服务器
HOST=0.0.0.0
PORT=8000

# CORS
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
